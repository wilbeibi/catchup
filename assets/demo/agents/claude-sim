#!/usr/bin/env bash
# DEMO SIM (left pane) — a scripted mimic of a Claude Code session that works on a
# task and then hits the 5-hour usage limit. Not the real Claude Code; it makes no
# API calls. Drives the "before" half of the handoff story.
set -u

o=$'\033[38;5;209m'    # Claude coral
g=$'\033[38;5;245m'    # muted bullets
rd=$'\033[38;5;203m'   # limit bar
yl=$'\033[38;5;179m'   # limit text
dim=$'\033[2m'; rs=$'\033[0m'

clear
printf '%s~/src/app%s\n' "$dim" "$rs"
printf '%s✷ Claude Code%s\n\n' "$o" "$rs"
sleep 0.5
printf '%s›%s fix the flaky auth test\n\n' "$o" "$rs"
sleep 1.3
printf '%s⏺%s Reading auth_test.go and the token-refresh path…\n' "$g" "$rs"
sleep 1.4
printf '%s⏺%s Found it: refreshToken() races — two goroutines\n' "$g" "$rs"
printf '   refresh at once and one clobbers the other'"'"'s token.\n'
sleep 1.5
printf '%s⏺%s Fix: guard the refresh with a sync.Mutex. Patching…\n' "$g" "$rs"
sleep 1.7
printf '\n%s  ────────────────────────────────────────────%s\n' "$rd" "$rs"
printf '  %s✗ You'"'"'ve reached your 5-hour limit.%s\n' "$yl" "$rs"
printf '  %s  Your limit resets at 9:00 PM.%s\n' "$dim" "$rs"
printf '%s  ────────────────────────────────────────────%s\n' "$rd" "$rs"
sleep 0.6
printf '\n%s  (session paused)%s\n' "$dim" "$rs"
sleep 20   # hold the final frame for the recorder; killed when the demo ends
